        "python-cli/argparse-patterns",
        "python-cli/click-commands",
        "python-cli/error-handling",
        "python-cli/config-management"
      ],
      "triggers": [
        {
          "type": "import",
          "pattern": "import argparse"
        },
        {
          "type": "import",
          "pattern": "import click"
        },
        {
          "type": "import",
          "pattern": "import typer"
        },
        {
          "type": "file",
          "pattern": "__main__.py"
        },
        {
          "type": "file",
          "pattern": "cli.py"
        },
        {
          "type": "dependency",
          "package": "click"
        },
        {
          "type": "dependency",
          "package": "typer"
        }
      ]
    },

# Copy this file to .env and fill in the keys you want to use.
# At least one LLM provider key is required for AI-enabled commands
# (design, plan, review, and skill generation with --ai).
# Offline commands (init, analyze, create-rules) work without any key.

# ── LLM provider API keys ────────────────────────────────────────────────
# Google Gemini (recommended — fast, generous free tier)
GEMINI_API_KEY=your_gemini_api_key_here
# Fallback alias that the Google SDK also recognises. If both are set,
# GEMINI_API_KEY wins. Useful if you already have GOOGLE_API_KEY from
# gcloud and don't want to duplicate it.
# GOOGLE_API_KEY=your_gemini_api_key_here

# Groq (fast, free tier — default provider for skill generation)
GROQ_API_KEY=your_groq_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional: pin specific model names ──────────────────────────────────
# Each provider falls back to a sensible default if these are unset.
# Use these to lock your runs to a specific model version, or to opt into
# a cheaper/faster model on the free tier.
# GEMINI_MODEL=gemini-2.5-flash-lite
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# OPENAI_MODEL=gpt-4o-mini

# ── Optional: observability ─────────────────────────────────────────────
# Opik (Comet) integration for tracing AI calls. Install with
# `pip install -e ".[opik]"` — disabled unless OPIK_API_KEY is set.
# OPIK_API_KEY=your_opik_api_key_here

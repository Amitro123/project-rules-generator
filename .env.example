# Copy this file to .env and fill in the keys you want to use.
# At least one LLM provider key is required for skill generation.

# Google Gemini (recommended — used by default when --provider gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (fast, free tier available — default provider)
GROQ_API_KEY=your_groq_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
